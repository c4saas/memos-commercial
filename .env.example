# ─────────────────────────────────────────────────────────────
#  Memos — White-label PARTNER deployment template
#
#  Copy this to `.env` in your partner deployment directory and
#  fill in:
#    - secrets (POSTGRES_PASSWORD, SESSION_SECRET, ENCRYPTION_KEY)
#    - partner branding (BRAND_NAME, BRAND_LOGO_URL, colors)
#    - the partner admin's email
# ─────────────────────────────────────────────────────────────

APP_VERSION=latest
COMPOSE_PROJECT_NAME=memos-partner

# Generate each: openssl rand -hex 32
POSTGRES_PASSWORD=
SESSION_SECRET=
ENCRYPTION_KEY=

MEMOS_DEFAULT_EMAIL=admin@partner.example
MEMOS_DEFAULT_NAME=Admin
# Set to issue a temp password on first boot; admin must change after login.
MEMOS_DEMO_PASSWORD=

HOST_PORT=3100
APP_BASE_URL=https://notes.partner.example
TRUST_PROXY=1

# ── White-label branding ────────────────────────────────────
BRAND_NAME=Partner Notes
BRAND_SHORT=Notes
BRAND_TAGLINE=AI meeting notes
BRAND_PRIMARY_HSL=210 100% 50%
BRAND_ACCENT_HSL=280 80% 60%
BRAND_SUPPORT_EMAIL=support@partner.example
BRAND_LOGO_URL=https://partner.example/logo.png
BRAND_FAVICON_URL=https://partner.example/favicon.png
BRAND_PRODUCT_URL=https://partner.example
BRAND_POWERED_BY=
BRAND_HIDE_POWERED_BY=1
